# HepatoScan AI Environment Variables
# Copy this file to .env and fill in your values

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=hepatoscan-ai
WANDB_ENTITY=your_username

# Model Weights
PRETRAINED_WEIGHTS_PATH=swin_unetr.pt

# Data Paths
DATA_ROOT=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Inference
DEVICE=cuda
INFERENCE_PATCH_SIZE=96
NUM_MC_SAMPLES=20

# API
API_HOST=0.0.0.0
API_PORT=8000
